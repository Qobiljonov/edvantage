# ── EdTech Server Settings ──
# This file is read by the server at startup and updated by the admin panel.

# Ollama model to use for generating answers (English)
LLM_MODEL='deepseek-r1:1.5b'

# Ollama model to use for multilingual answers (Uzbek/Russian)
LLM_MODEL_MULTILINGUAL='deepseek-r1:1.5b'

# Number of context chunks to retrieve from the vector database
TOP_K='3'

# Cosine distance threshold — chunks above this are flagged as irrelevant
RELEVANCE_THRESHOLD='0.45'

# Temperature for LLM generation (0.0 = deterministic, 1.0 = creative)
TEMPERATURE='0.6'
